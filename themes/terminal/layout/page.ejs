<article class="terminal-article">
  <div class="prompt-line"><span>$</span> cat <%- (page.source || page.path || 'page.md').replace(/^source\//, '') %></div>
  <header class="article-head">
    <h1><%- page.title %></h1>
  </header>
  <div class="terminal-content">
    <%- page.content %>
  </div>
</article>
